# ────────────────────────────────────────────────
# Resound — .gitignore
# ────────────────────────────────────────────────

# Rust / Cargo
target/
**/*.rs.bk
*.pdb

# wasm-pack output
# (we emit to web/wasm via --out-dir; pkg/ is the default fallback)
web/wasm/
pkg/

# esbuild-bundled AudioWorklet (generated by the build:worklet npm script)
web/public/mm01-worklet.js

# Node / Vite
node_modules/
dist/
.vite/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment files (reserved for future Freesound proxy etc.)
.env
.env.local
.env.*.local

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Test / coverage
coverage/

# VCV Rack reference checkouts (see docs/architecture.md → DSP Code)
reference/

# TS incremental build state
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo
