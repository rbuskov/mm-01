# ────────────────────────────────────────────────
# Resound — .gitignore
# ────────────────────────────────────────────────

# Rust / Cargo
target/
**/*.rs.bk
*.pdb

# wasm-pack output
# (we emit to src/web/wasm via --out-dir; pkg/ is the default fallback)
src/web/wasm/
pkg/

# Node / Vite
node_modules/
dist/
.vite/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment files (reserved for future Freesound proxy etc.)
.env
.env.local
.env.*.local

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Test / coverage
coverage/
