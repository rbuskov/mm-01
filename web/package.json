{
  "name": "mm01-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/mm01-dsp --target web --release --out-dir ../../web/wasm",
    "build:worklet": "esbuild audio/worklet.ts --bundle --format=iife --target=es2022 --outfile=public/mm01-worklet.js --log-override:empty-import-meta=silent",
    "dev": "npm run build:wasm && npm run build:worklet && vite",
    "build": "npm run build:wasm && npm run build:worklet && tsc -b && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
